# =============================================================================
# SELF-INSTALL LOGIC - UPDATED TO v2 (April 2026)
# =============================================================================
#
# CRITICAL DEFENSIVE FUNCTION - DO NOT SIMPLIFY, REMOVE, OR REFACTOR
#
# New in v2 (perform_self_install):
#   1. If environment variable CHECKSUM=<sha256> is set (e.g. exported by user or CI),
#      the script will:
#        • Download the script from ${SCRIPT_URL}
#        • Verify the downloaded content against the provided CHECKSUM using sha256sum
#        • Only proceed with installation if the checksum matches exactly
#        • This allows users/CI to pin a known-good version and protect against
#          MITM, compromised GitHub raw, or network tampering.
#
#   2. If CHECKSUM is NOT set (normal interactive/one-liner usage):
#        • First attempt: curl ${SCRIPT_URL} (the script itself)
#        • Second attempt: also fetch ${SCRIPT_URL}.sha256 (if HTTP 200)
#        • If the .sha256 file exists and is valid, verify the downloaded script
#          with "sha256sum -c"
#        • If verification fails → die with clear error (incorrect checksum)
#        • If no .sha256 file or verification skipped → proceed (backward compatible)
#
# Why this v2 protection is needed (Defensive Reasoning):
#   • The classic `curl | sh` pattern is convenient but inherently risky.
#   • GitHub raw content can be tampered with via account compromise, supply-chain attack,
#     or transient network interception.
#   • Providing both an explicit CHECKSUM env var and automatic .sha256 lookup
#     significantly reduces the attack surface for one-command installs.
#   • Maintains full backward compatibility for users who do not provide CHECKSUM.
#   • Aligns with CIAO-Lite "Caution" and "Over-protect" principles.
#   • Prevents silent installation of malicious code — fail loudly on checksum mismatch.
#
# Updated from previous version:
#   • Old: perform_self_install() performed blind download + move.
#   • New: perform_self_install() adds layered checksum verification while keeping
#     the rest of the installation logic (temp file, permissions, PATH handling) identical.
#   • The function name was deliberately changed to perform_self_install to clearly
#     signal the security upgrade. Old name is preserved in comments for reference.
#   • All other self-update / self-uninstall logic continues to call the v2 version.
#
# !!! THIS IS THE SINGLE SOURCE OF TRUTH FOR SELF-INSTALLATION !!!
# !!! DO NOT RENAME BACK, DO NOT MERGE WITH OTHER FUNCTIONS !!!
# !!! ALWAYS CALL perform_self_install() FOR NEW INSTALLS !!!
# Shebang remains #!/bin/sh - defensive and portable.
# Repeated safe defaults and heavy comments are intentional.
#
# Aligned with https://github.com/Wilgat/ciao
# Last aligned: 28 April 2026
# =============================================================================

perform_self_install() {
    : "${GLOBAL_BIN:=/usr/local/bin}"
    : "${USER_BIN:=${HOME}/.local/bin}"
    : "${INSTALL_PATH:=${GLOBAL_BIN}/${APP_NAME}}"

    if [ "$(id -u)" -eq 0 ]; then
        IS_ROOT=1
        INSTALL_PATH="${GLOBAL_BIN}/${APP_NAME}"
    else
        IS_ROOT=0
        INSTALL_PATH="${USER_BIN}/${APP_NAME}"
    fi

    if [ -z "$REMOTE_VERSION" ]; then
        REMOTE_VERSION=${VERSION}
    fi

    if [ "${JSON}" -eq 0 ]; then
        info "Starting installation of ${APP_NAME} ${REMOTE_VERSION}..."
    fi

    if is_installed && [ "${FORCE_REINSTALL}" -eq 0 ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json "success" "message" "${APP_NAME} is already installed."
        else
            success "${APP_NAME} is already installed. Use --force to override."
        fi
        return 0
    fi

    # Step 1: Prepare target folder
    if ! perform_self_install_prepare_target; then
        return 1
    fi

    local tmp_file
    tmp_file=$(mktemp -t "${APP_NAME}.XXXXXX") || {
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Failed to create temporary file" "io_error"
        else
            error "Failed to create temporary file"
        fi
        return 1
    }

    # Step 2 & 3: Download (with or without checksum)
    local downloaded_checksum_ok=0
    if [ -n "${CHECKSUM:-}" ]; then
        if ! perform_self_install_download_with_checksum "$tmp_file"; then
            rm -f "${tmp_file}"
            return 1
        fi
        downloaded_checksum_ok=1
    else
        if ! perform_self_install_download_without_checksum "$tmp_file"; then
            rm -f "${tmp_file}"
            return 1
        fi
        # downloaded_checksum_ok remains 0 if no .sha256 was used
    fi

    # Step 4: Atomic copy to final location
    if ! perform_self_install_atomic_install "$tmp_file" "$downloaded_checksum_ok"; then
        return 1
    fi

    return 0
}

# =============================================================================
# perform_self_install_prepare_target() - Step 1: Target folder preparation
# =============================================================================
#
# GENERAL PURPOSE:
# Creates the correct installation directory (global or user) with proper
# permissions check.
#
# Last reviewed: 28 April 2026
# =============================================================================

perform_self_install_prepare_target() {
    if [ "$IS_ROOT" -eq 1 ]; then
        if ! mkdir -p "${GLOBAL_BIN}" 2>/dev/null; then
            if [ "${JSON}" -eq 1 ]; then
                output_json_error "Failed to create ${GLOBAL_BIN}" "io_error"
            else
                error "Failed to create ${GLOBAL_BIN}"
            fi
            return 1
        fi
    else
        if ! mkdir -p "${USER_BIN}" 2>/dev/null; then
            if [ "${JSON}" -eq 1 ]; then
                output_json_error "Failed to create ${USER_BIN}" "io_error"
            else
                error "Failed to create ${USER_BIN}"
            fi
            return 1
        fi
    fi
    return 0
}

# =============================================================================
# perform_self_install_download_with_checksum() - Step 2: Download with explicit CHECKSUM
# =============================================================================
#
# GENERAL PURPOSE:
# Downloads the script and verifies it against user-provided CHECKSUM (strict).
#
# Last reviewed: 28 April 2026
# =============================================================================

perform_self_install_download_with_checksum() {
    local tmp_file="$1"

    if [ "${JSON}" -eq 0 ]; then
        info "Verifying download against provided CHECKSUM..."
    fi

    if command -v curl >/dev/null 2>&1; then
        curl -fsSL "${SCRIPT_URL}" -o "${tmp_file}" || {
            if [ "${JSON}" -eq 1 ]; then
                output_json_error "Download failed (curl)" "network_error"
            else
                error "Download failed (curl)"
            fi
            return 1
        }
    elif command -v wget >/dev/null 2>&1; then
        wget -qO "${tmp_file}" "${SCRIPT_URL}" || {
            if [ "${JSON}" -eq 1 ]; then
                output_json_error "Download failed (wget)" "network_error"
            else
                error "Download failed (wget)"
            fi
            return 1
        }
    else
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Neither curl nor wget found" "missing_dependency"
        else
            error "Neither curl nor wget found"
        fi
        return 1
    fi

    # Verify provided CHECKSUM
    if printf '%s  %s\n' "${CHECKSUM}" "${tmp_file}" | sha256sum -c - >/dev/null 2>&1; then
        if [ "${JSON}" -eq 0 ]; then
            success "Checksum verification passed (user-provided CHECKSUM)."
        fi
        return 0
    else
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Checksum verification failed (provided CHECKSUM does not match)" "checksum_mismatch"
        else
            die "Checksum verification failed. The downloaded file does not match the provided CHECKSUM. Installation aborted for security."
        fi
        return 1
    fi
}

# =============================================================================
# perform_self_install_download_without_checksum() - Step 3: Download with automatic .sha256
# =============================================================================
#
# GENERAL PURPOSE:
# Downloads the script and attempts best-effort verification via ${SCRIPT_URL}.sha256.
# Falls back gracefully if no .sha256 file exists (backward compatible).
#
# Last reviewed: 28 April 2026
# =============================================================================

perform_self_install_download_without_checksum() {
    local tmp_file="$1"

    if [ "${JSON}" -eq 0 ]; then
        info "No CHECKSUM provided → attempting automatic verification via ${SCRIPT_URL}.sha256"
    fi

    if command -v curl >/dev/null 2>&1; then
        curl -fsSL "${SCRIPT_URL}" -o "${tmp_file}" || {
            if [ "${JSON}" -eq 1 ]; then
                output_json_error "Download failed (curl)" "network_error"
            else
                error "Download failed (curl)"
            fi
            return 1
        }

        local sha_file
        sha_file=$(mktemp -t "${APP_NAME}.sha256.XXXXXX") || return 1

        if curl -fsSL -w "%{http_code}" "${SCRIPT_URL}.sha256" -o "${sha_file}" 2>/dev/null | grep -q "^200"; then
            if sha256sum -c "${sha_file}" --status 2>/dev/null < "${tmp_file}"; then
                if [ "${JSON}" -eq 0 ]; then
                    success "Automatic checksum verification passed (${SCRIPT_URL}.sha256)."
                fi
            else
                rm -f "${sha_file}"
                if [ "${JSON}" -eq 1 ]; then
                    output_json_error "Automatic checksum verification failed" "checksum_mismatch"
                else
                    die "Checksum verification failed (mismatch with ${SCRIPT_URL}.sha256). Installation aborted for security."
                fi
                return 1
            fi
        else
            if [ "${JSON}" -eq 0 ]; then
                warn "No .sha256 file found at ${SCRIPT_URL}.sha256 → continuing without automatic verification."
            fi
        fi
        rm -f "${sha_file}" 2>/dev/null || true

    elif command -v wget >/dev/null 2>&1; then
        # wget branch (kept minimal)
        wget -qO "${tmp_file}" "${SCRIPT_URL}" || {
            if [ "${JSON}" -eq 1 ]; then
                output_json_error "Download failed (wget)" "network_error"
            else
                error "Download failed (wget)"
            fi
            return 1
        }

        local sha_file
        sha_file=$(mktemp -t "${APP_NAME}.sha256.XXXXXX") || return 1

        if wget -q --server-response "${SCRIPT_URL}.sha256" -O "${sha_file}" 2>&1 | grep -q "HTTP/1.1 200"; then
            if sha256sum -c "${sha_file}" --status 2>/dev/null < "${tmp_file}"; then
                if [ "${JSON}" -eq 0 ]; then
                    success "Automatic checksum verification passed."
                fi
            else
                rm -f "${sha_file}"
                if [ "${JSON}" -eq 1 ]; then
                    output_json_error "Automatic checksum verification failed" "checksum_mismatch"
                else
                    die "Checksum verification failed. Installation aborted for security."
                fi
                return 1
            fi
        else
            if [ "${JSON}" -eq 0 ]; then
                warn "No .sha256 file found → continuing without automatic verification."
            fi
        fi
        rm -f "${sha_file}" 2>/dev/null || true
    else
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Neither curl nor wget found" "missing_dependency"
        else
            error "Neither curl nor wget found"
        fi
        return 1
    fi

    return 0
}

# =============================================================================
# perform_self_install_atomic_install() - Step 4: Atomic copy to target location
# =============================================================================
#
# GENERAL PURPOSE:
# Makes the downloaded file executable and atomically moves it to the final
# INSTALL_PATH. Also handles PATH addition for user installs and success output.
#
# Last reviewed: 28 April 2026
# =============================================================================

perform_self_install_atomic_install() {
    local tmp_file="$1"
    local downloaded_checksum_ok="$2"

    chmod +x "${tmp_file}" 2>/dev/null || true

    rm -f "${INSTALL_PATH}" 2>/dev/null
    if ! mv "${tmp_file}" "${INSTALL_PATH}" 2>/dev/null; then
        rm -f "${tmp_file}"
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Failed to move to ${INSTALL_PATH}" "io_error"
        else
            error "Failed to move to ${INSTALL_PATH}"
        fi
        return 1
    fi

    # Add ~/.local/bin to PATH for normal user installs
    if [ "$IS_ROOT" -eq 0 ]; then
        add_to_shell_path
    fi
    
    if [ "${JSON}" -eq 1 ]; then
        output_json "success" "message" "${APP_NAME} ${REMOTE_VERSION} successfully installed to ${INSTALL_PATH}"
    else
        success "${APP_NAME} ${REMOTE_VERSION} successfully installed to ${INSTALL_PATH}"
        if [ "${downloaded_checksum_ok}" -eq 1 ]; then
            success "✓ Download was cryptographically verified."
        fi
    fi
    return 0
}

# =============================================================================
# prompt_yes_no() - Defensive interactive yes/no confirmation prompt
# =============================================================================
#
# GENERAL PURPOSE:
# Displays a message and waits for (y/N) confirmation.
# Returns 0 if user says yes, returns 1 (non-zero) if user says no or cancels.
#
# CRITICAL DEFENSIVE RULES (DO NOT VIOLATE):
# 1. Must ALWAYS go through single source of truth (msg_n + output_text)
# 2. Must respect --quiet and --json (never show prompt in those modes)
# 3. Must NEVER use raw printf/echo for user-visible text
# 4. Must work correctly in non-interactive / curl | sh environments
# 5. Must preserve TTY detection and color handling via output_text
# 6. This is the SINGLE SOURCE OF TRUTH for all yes/no confirmations in the project.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# Past AI assistants have repeatedly replaced this kind of prompt with
# raw printf + read, breaking consistency with output_text(), --quiet,
# --json, TTY detection, and the overall defensive design.
#
# This helper exists specifically to prevent that regression and to enforce
# CIAO-Lite principles of Caution, Intentionality, and Over-protect.
#
# Last reviewed & aligned: 28 April 2026
# =============================================================================

prompt_yes_no() {
    # --- Safe Variable Defaults ----
    # Defensive defaults - never assume globals are set
    : "${JSON:=0}"
    : "${QUIET:=0}"

    local message="$1"

    # Never show prompt in quiet or json mode
    if [ "${JSON}" -eq 1 ] || [ "${QUIET}" -eq 1 ]; then
        return 1   # treat as "no" in non-interactive modes
    fi

    # Must be interactive TTY
    if ! [ -t 0 ] || ! [ -t 1 ]; then
        return 1
    fi

    msg_n "${message} (y/N)? "

    local answer=""
    read -r answer || true

    case "$answer" in
        [Yy]*|[Yy][Ee][Ss]*)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

# =============================================================================
# maybe_install() - Friendly installation prompt
# =============================================================================
#
# Respects both --quiet and --json modes.
# In JSON mode we skip the interactive prompt entirely.
# Now uses prompt_yes_no() as single source of truth for confirmation.
#
# !!! DO NOT MODIFY OR SIMPLIFY !!!
# Designed to be reusable in other projects.
#
# Last aligned: 22 April 2026
# =============================================================================

maybe_install() {
    : "${QUIET:=0}"
    : "${JSON:=0}"
    : "${FORCE_REINSTALL:=0}"
    
    if is_installed && [ "${FORCE_REINSTALL}" -eq 0 ]; then
        return 0
    fi
    # In JSON mode or quiet mode we do not show interactive prompts
    if [ "${JSON}" -eq 1 ] || [ "${QUIET}" -eq 1 ]; then
        return 0
    fi
    empty_line
    msg "Note: '${APP_NAME}' is not installed yet."
    msg "     Version: ${VERSION}"
    empty_line
    msg "Recommended installation command:"
    empty_line

    if [ "$IS_ROOT" -eq 1 ]; then
        msg "     sudo curl -fsSL ${SCRIPT_URL} | sudo ${SH}"
    else
        msg "     curl -fsSL ${SCRIPT_URL} | ${SH}"
    fi
    empty_line

    local should_install=false

    if [ -t 0 ] && [ -t 1 ]; then
        # Use single source of truth for the yes/no prompt
        if prompt_yes_no "Install ${APP_NAME} ${VERSION} now?"; then
            should_install=true
        else
            should_install=false
            msg "Installation skipped by user."
            return 0 
        fi
    else
        msg "Non-interactive mode detected → installing automatically..."
        should_install=true
    fi

    if [ "$should_install" = "true" ]; then
        perform_self_install
        exit 0
    fi
}


# =============================================================================
# show_about_git_sync() - Display diagnostic information about the current environment
# =============================================================================
#
# GENERAL PURPOSE:
# Shows detailed diagnostic information: version, installation status (global + local),
# current shell, TTY/interactive status, user, and helpful next steps.
#
# Fully respects --quiet and --json modes.
# In JSON mode: outputs exactly ONE clean, machine-readable JSON object.
# In quiet mode: prints nothing.
#
# This function provides real value to users (unlike the previous overly simple version)
# and should be kept in sync with the overall CIAO design and README.md.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# Designed to be reusable in other CIAO projects.
#
# Last reviewed: 28 April 2026
# =============================================================================
show_about_git_sync() {
    if [ "${JSON}" -eq 1 ]; then
        # === JSON MODE - Clean, machine-friendly output ===
        local installed="false"
        is_installed && installed="true"

        local global_ver="not found"
        if [ -x "${GLOBAL_BIN}/${APP_NAME}" ]; then
            global_ver=$(grep '^VERSION="' "${GLOBAL_BIN}/${APP_NAME}" 2>/dev/null | cut -d'"' -f2 || echo "unknown")
        fi

        local local_ver="not found"
        if [ -x "${USER_BIN}/${APP_NAME}" ]; then
            local_ver=$(grep '^VERSION="' "${USER_BIN}/${APP_NAME}" 2>/dev/null | cut -d'"' -f2 || echo "unknown")
        fi

        # Improved shell detection to avoid showing the script name itself
        local current_shell="unknown"
        current_shell=$(ps -p $$ -o comm= 2>/dev/null | tr -d '()' || echo "unknown")
        
        if [ "$current_shell" = "${APP_NAME}" ] || [ "$current_shell" = "sh" ] || \
           [ "$current_shell" = "dash" ] || [ "$current_shell" = "ash" ]; then
            local parent_pid
            parent_pid=$(ps -p $$ -o ppid= 2>/dev/null | tr -d ' ')
            if [ -n "$parent_pid" ]; then
                current_shell=$(ps -p "$parent_pid" -o comm= 2>/dev/null | tr -d '()' || echo "$current_shell")
            fi
        fi

        local interactive="false"
        [ -t 1 ] && interactive="true"

        output_json "about" "" \
            "app" "${APP_NAME}" \
            "version" "${VERSION}" \
            "installed" "${installed}" \
            "global_version" "${global_ver}" \
            "local_version" "${local_ver}" \
            "shell" "${current_shell}" \
            "interactive" "${interactive}" \
            "user" "${USERNAME}" 

        return 0
    fi

    # === Normal Human-readable Mode ===
    [ "${QUIET}" -eq 1 ] && return 0

    msg "=== ${APP_NAME} ${VERSION} - About / Diagnostics ==="
    empty_line

    # Installation status
    if is_installed; then
        success "${APP_NAME} is properly installed."
    else
        warn "${APP_NAME} is NOT installed in your PATH."
        if [ -t 1 ]; then
            msg "   Recommended one-liner:"
            msg "     curl -fsSL ${SCRIPT_URL} | sh"
        else
            msg "   Recommended: curl -fsSL ${SCRIPT_URL} | sh"
        fi
    fi

    empty_line

    # Global vs Local installation details
    if [ -x "${GLOBAL_BIN}/${APP_NAME}" ]; then
        global_ver=$(grep '^VERSION="' "${GLOBAL_BIN}/${APP_NAME}" 2>/dev/null | cut -d'"' -f2 || echo "unknown")
        msg "Global install  (${GLOBAL_BIN}/${APP_NAME}):   ${global_ver}"
    else
        msg "Global install  (${GLOBAL_BIN}/${APP_NAME}):   not found"
    fi

    if [ -x "${USER_BIN}/${APP_NAME}" ]; then
        local_ver=$(grep '^VERSION="' "${USER_BIN}/${APP_NAME}" 2>/dev/null | cut -d'"' -f2 || echo "unknown")
        msg "Local install   (${USER_BIN}/${APP_NAME}):    ${local_ver}"
    else
        msg "Local install   (${USER_BIN}/${APP_NAME}):    not found"
    fi

    empty_line

    # Shell & Environment
    local current_shell="unknown"
    current_shell=$(ps -p $$ -o comm= 2>/dev/null | tr -d '()' || echo "unknown")
    
    if [ "$current_shell" = "${APP_NAME}" ] || [ "$current_shell" = "sh" ] || \
       [ "$current_shell" = "dash" ] || [ "$current_shell" = "ash" ]; then
        local parent_pid
        parent_pid=$(ps -p $$ -o ppid= 2>/dev/null | tr -d ' ')
        if [ -n "$parent_pid" ]; then
            current_shell=$(ps -p "$parent_pid" -o comm= 2>/dev/null | tr -d '()' || echo "$current_shell")
        fi
    fi

    msg "Current shell:     ${current_shell}"
    msg "User:              ${USERNAME}"

    if [ -t 1 ]; then
        msg "TTY / Interactive: yes"
    else
        msg "TTY / Interactive: no (non-interactive / scripted mode)"
    fi

    empty_line
    msg "Useful commands:"
    msg "   ${APP_NAME} help          → Full usage and examples"
    msg "   ${APP_NAME} self-update   → Update to latest version"
    msg "   ${APP_NAME} self-uninstall → Clean removal from system"
    msg "   ${APP_NAME} --json        → Machine-readable output"

    empty_line
    msg "Run '${APP_NAME} help' for complete usage information."
}

