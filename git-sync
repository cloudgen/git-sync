#!/bin/sh
# =============================================================================
# git-sync – version 1.0.4
# =============================================================================
#
# Scans direct subfolders for Git repos (.git), resets --hard HEAD, pulls origin main.
# Portable, self-installing — works via curl | sh on Linux/macOS/Alpine/BSD.
#
# One-liner install (user): curl -fsSL https://raw.githubusercontent.com/cloudgen/git-sync/main/git-sync | sh
# Root/system-wide:      curl -fsSL https://raw.githubusercontent.com/cloudgen/git-sync/main/git-sync | sudo sh
#
# Usage: git-sync [START_DIR]  (defaults to .)
#
# Adapted from countdown CIAO base — defensive/portable/no-deps .
# See [CIAO](https://github.com/cloudgen/ciao)
# =============================================================================

# ----------------------------- Project Constants -----------------------------
APP_NAME="git-sync"            # HARDCODED for curl | sh
VERSION="1.0.4"
DESCRIPTION="Git reset+pull for subfolder repos"
REPO_USER="cloudgen"               
REPO_NAME="git-sync"
SCRIPT_URL="https://raw.githubusercontent.com/${REPO_USER}/${REPO_NAME}/main/${APP_NAME}"

# Force/Mode Flags (defaults)
: "${FORCE_USER:=0}"
: "${FORCE_GLOBAL:=1}"
: "${FORCE_REINSTALL:=0}"
: "${QUIET:=0}"
: "${JSON:=0}"

# Paths (defensive defaults)
: "${GLOBAL_BIN:=/usr/local/bin}"
: "${USER_BIN:=${HOME}/.local/bin}"
: "${INSTALL_PATH:=${GLOBAL_BIN}/${APP_NAME}}"

# =============================================================================
# Root Detection (Single Source of Truth)
# =============================================================================
if [ -z "${IS_ROOT:-}" ]; then
    if [ "$(id -u)" -eq 0 ]; then
        IS_ROOT=1
        INSTALL_PATH="${GLOBAL_BIN}/${APP_NAME}"
    else
        IS_ROOT=0
        INSTALL_PATH="${USER_BIN}/${APP_NAME}"
    fi
fi

[ -t 0 ] && [ -t 1 ] && TTY=1
USERNAME="$(id -un 2>/dev/null || echo unknown)"

# =============================================================================
# output_text() - SINGLE SOURCE OF TRUTH FOR ALL OUTPUT
# =============================================================================
output_text() {
    local level="$1" msg="$2"
    : "${JSON:=0}" : "${QUIET:=0}"
    [ "${JSON}" -eq 1 ] && return 0
    [ "${QUIET}" -eq 1 ] && [ "${level}" != "error" ] && return 0

    local RED='' GREEN='' YELLOW='' BLUE='' NC=''
    [ "${TTY:-0}" -eq 1 ] && [ "${QUIET}" -eq 0 ] && [ "${JSON}" -eq 0 ] && {
        RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; NC='\033[0m'
    }

    case "${level}" in
        error) printf >&2 "${RED}[ERROR]${NC} %s\n" "${msg}" ;; warn) printf >&2 "${YELLOW}[WARN]${NC} %s\n" "${msg}" ;;
        info) printf "${GREEN}[INFO]${NC} %s\n" "${msg}" ;; success) printf "${GREEN}[OK]${NC} %s\n" "${msg}" ;;
        plain) printf "%s\n" "${msg}" ;; plain_n) printf "%s" "${msg}" ;;
        *) printf "%s\n" "${msg}" ;;
    esac
}

output_json() {
    [ "${JSON}" -eq 0 ] && return 0
    local type="$1" message="$2"; shift 2
    printf '{'
    printf '"type":"%s"' "$type"
    [ -n "$message" ] && printf ',"message":"%s"' "$(printf '%s' "$message" | sed 's/"/\\"/g')"
    while [ $# -ge 2 ]; do printf ',"%s":"%s"' "$1" "$2"; shift 2; done
    printf '}\n'
}

output_json_error() { output_json "error" "$1" "code" "${2:-unknown}"; }

msg_n() { output_text plain_n "$*"; }
die() { output_json_error "$*" >&2; output_text error "$*"; exit 1; }
info() { output_text info "$*"; }
success() { output_text success "$*"; }
warn() { output_text warn "$*"; }
msg() { output_text plain "$*"; }
empty_line() { output_text plain ""; }
double_line() { output_text plain "=================================================="; }

# =============================================================================
# is_installed() - Robust installation check
# =============================================================================
#
# GENERAL PURPOSE:
# Checks whether the program is already installed, supporting both root
# and normal user installations with safe fallbacks.
#
# Please don't modify this code for root-only installed
# You can check [ "$(id -u)" -eq 0 ] before calling / excuting 
#   this function
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# Designed to be reusable in other projects.
# =============================================================================

is_installed() {
    : "${GLOBAL_BIN:=/usr/local/bin}"
    : "${USER_BIN:=${HOME}/.local/bin}"
    : "${INSTALL_PATH:=${GLOBAL_BIN}/${APP_NAME}}"

    if [ "$(id -u)" -eq 0 ]; then
        IS_ROOT=1
        INSTALL_PATH="${GLOBAL_BIN}/${APP_NAME}"
    else
        IS_ROOT=0
        INSTALL_PATH="${USER_BIN}/${APP_NAME}"
    fi

    # Support explicit parameters or force flags
    if [ "${1:-}" = "--user" ] || [ "${FORCE_USER:-0}" -eq 1 ]; then
        [ -f "${USER_BIN}/${APP_NAME}" ] && [ -x "${USER_BIN}/${APP_NAME}" ] && return 0
        return 1
    elif [ "${1:-}" = "--global" ] || [ "${FORCE_GLOBAL:-0}" -eq 1 ]; then
        [ -f "${GLOBAL_BIN}/${APP_NAME}" ] && [ -x "${GLOBAL_BIN}/${APP_NAME}" ] && return 0
        return 1
    fi

    # Main logic
    if [ "$IS_ROOT" -eq 1 ]; then
        [ -f "${INSTALL_PATH}" ] && [ -x "${INSTALL_PATH}" ]
    else
        { [ -f "${GLOBAL_BIN}/${APP_NAME}" ] && [ -x "${GLOBAL_BIN}/${APP_NAME}" ]; } ||
        { [ -f "${USER_BIN}/${APP_NAME}"   ] && [ -x "${USER_BIN}/${APP_NAME}"   ]; }
    fi
}

# =============================================================================
# get_installed_version_v1() - Extract version from installed binary
# =============================================================================
#
# GENERAL PURPOSE:
# Safely reads the VERSION constant from the installed script.
# Used by --version-check and --self-update.
#
# Safe Variable Defaults
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# Designed to be reusable in other projects.
#
# CRITICAL WARNING - VERSION EXTRACTION IS ESSENTIAL FOR SELF-UPDATE:
# Knowing the exact installed version is not optional — it is the foundation
# of safe self-update and version-check logic.
#
# Without a reliable get_installed_version_v1(), self-update cannot properly
# compare local version against remote, leading to:
# - Unnecessary re-downloads
# - Failed updates
# - Silent failures
# - Potential downgrade or broken installation
#
# AI assistants frequently fail to respect this importance. They often
# overlook, simplify, or remove version extraction logic because they
# consider it "minor" or try to replace the entire self-update flow with
# a simpler approach. This always breaks the self-update mechanism.
#
# This function is battle-field tested and intentionally simple/robust
# (grep + cut on the VERSION= line). Any attempt to rewrite or bypass it
# risks destroying the self-update safety net.
#
# We must intentionally preserve and reuse this exact function instead of
# replacing it. Respecting version awareness is a core part of CIAO
# Caution and Anti-fragility.
#
# Last reviewed: 20 April 2026
# =============================================================================

get_installed_version_v1() {
    # --- Safe Variable Defaults ----
    # Defensive defaults - never assume globals are set
    : "${APP_NAME:=app}"
    : "${IS_ROOT:=0}"
    : "${GLOBAL_BIN:=/usr/local/bin}"
    : "${USER_BIN:=${HOME}/.local/bin}"

    local bin_path
    if [ "$IS_ROOT" -eq 1 ] || [ -x "${GLOBAL_BIN}/${APP_NAME}" ]; then
        bin_path="${GLOBAL_BIN}/${APP_NAME}"
    else
        bin_path="${USER_BIN}/${APP_NAME}"
    fi

    if [ -x "$bin_path" ]; then
        grep '^VERSION="' "$bin_path" 2>/dev/null | cut -d'"' -f2 || echo "unknown"
    else
        echo "not installed"
    fi
}

# =============================================================================
# version_gt_v1() - Pure POSIX semantic version comparison
# =============================================================================
#
# GENERAL PURPOSE:
# Returns 0 (true) if ver1 > ver2, otherwise returns 1 (false).
# Used by version_check_v1() and self_update() to prevent incorrect downgrades.
#
# Safe Variable Defaults
# Respects CIAO zero-dependency rule — no external tools (no sort -V).
#
# CRITICAL DESIGN CHOICE:
# This function was added because previous AI suggestions using `sort -V`
# were not portable enough for harsh environments (Alpine ash, busybox,
# minimal containers, Git Bash, etc.).
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# Past AI assistants have repeatedly tried to replace this with:
#   - `sort -V` one-liners
#   - Inline string comparisons
#   - "Cleaner" but less robust logic
#
# Any such change re-introduces downgrade bugs and breaks portability.
# This function must remain pure POSIX and self-contained.
#
# AI assistants are explicitly required to:
# - Never remove or inline this function
# - Always use it for all version comparisons in grokrec
# - Preserve all defensive comments
# - Study the test script provided by the user before suggesting changes
#
# This is part of the battle-field-tested defensive layer.
#
# Last reviewed & polished: 14 April 2026
# =============================================================================

version_gt_v1() {
    # --- Safe Variable Defaults ----
    v1=$1
    v2=$2

    while [ -n "$v1" ] || [ -n "$v2" ]; do
        p1=${v1%%.*}
        p2=${v2%%.*}

        [ -z "$p1" ] && p1=0
        [ -z "$p2" ] && p2=0

        if [ "$p1" -gt "$p2" ]; then
            return 0
        fi
        if [ "$p1" -lt "$p2" ]; then
            return 1
        fi

        if [ "$v1" = "${v1#*.}" ]; then
            v1=""
        else
            v1=${v1#*.}
        fi

        if [ "$v2" = "${v2#*.}" ]; then
            v2=""
        else
            v2=${v2#*.}
        fi
    done

    return 1    # versions are equal
}

# =============================================================================
# version_check_v1() - Compare local vs remote version + suggest install
# =============================================================================
#
# GENERAL PURPOSE:
# Fetches the latest version from GitHub raw and compares with installed one.
#
# Safe Variable Defaults
# Respects --quiet and --json.
#
# CRITICAL WARNING - VERSION CHECK IS THE SAFETY GATE FOR SELF-UPDATE:
# This function is the core safety mechanism that prevents blind or
# unnecessary updates. It relies on get_installed_version_v1() to know the
# current version before deciding whether to update.
#
# CRITICAL DEFENSIVE IMPROVEMENT (14 April 2026):
# Now uses version_gt_v1() for proper semantic comparison to prevent
# downgrade when local version is newer (development builds).
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# Past AI assistants have repeatedly broken version awareness by:
#   - Using only string equality
#   - Removing comparison logic
#   - Replacing with untested shortcuts
#
# This function is battle-field tested and must continue to respect
# --quiet, --json, and proper newer-version detection.
#
# Last reviewed & polished: 14 April 2026
# =============================================================================

version_check_v1() {
    # --- Safe Variable Defaults ----
    # Defensive defaults - never assume globals are set
    : "${APP_NAME:=app}"
    : "${JSON:=0}"
    : "${QUIET:=0}"
    : "${SCRIPT_URL:=https://raw.githubusercontent.com/cloudgen/grokrec/main/grokrec}"

    # Fetch remote version
    REMOTE_VERSION=$(curl -fsSL "${SCRIPT_URL}" 2>/dev/null | grep '^VERSION="' | cut -d'"' -f2 || echo "")

    if [ -z "$REMOTE_VERSION" ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Failed to fetch remote version" "network_error"
        else
            error "Failed to fetch remote version"
        fi
        return 1
    fi

    local local_version
    local_version=$(get_installed_version_v1)

    if [ "${JSON}" -eq 1 ]; then
        output_json "version_check_v1" \
            "local_version" "$local_version" \
            "remote_version" "$REMOTE_VERSION" \
            "is_latest" "$( [ "$local_version" = "$REMOTE_VERSION" ] && echo "true" || \
                           (version_gt_v1 "$local_version" "$REMOTE_VERSION" && echo "true" || echo "false") )"
    else
        if [ "${QUIET}" -eq 0 ]; then
            info "Checking latest version of ${APP_NAME}..."
            msg "Local version : ${local_version}"
            msg "Latest version: ${REMOTE_VERSION}"
            empty_line

            if [ "$local_version" = "$REMOTE_VERSION" ]; then
                success "You are running the latest version."
            elif version_gt_v1 "$local_version" "$REMOTE_VERSION"; then
                success "You are running a newer development version (${local_version} > ${REMOTE_VERSION})"
            elif [ "$local_version" = "not installed" ]; then
                warn "${APP_NAME} is not installed yet."
            else
                warn "A newer version is available (${REMOTE_VERSION})"
            fi
        fi
    fi
}

# =============================================================================
# self_update_v3() - Perform self-update to latest version
# =============================================================================
#
# GENERAL PURPOSE:
# Downloads and installs the latest version from GitHub.
# Respects --force and --quiet.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# Designed to be reusable in other projects.
# =============================================================================

self_update_v3() {
    if [ "${JSON}" -eq 0 ]; then
        info "Starting self-update of ${APP_NAME}..."
    fi

    local REMOTE_VERSION
    REMOTE_VERSION=$(curl -fsSL "${SCRIPT_URL}" 2>/dev/null | grep '^VERSION="' | cut -d'"' -f2 || echo "")

    if [ -z "$REMOTE_VERSION" ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Failed to fetch latest version" "network_error"
        else
            error "Failed to fetch latest version"
        fi
        return 1
    fi

    local local_version
    local_version=$(get_installed_version_v1)

    if [ "$local_version" = "$REMOTE_VERSION" ] && [ "${FORCE_REINSTALL}" -eq 0 ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json "success" "message" "Already running the latest version (${REMOTE_VERSION})."
        else
            success "Already running the latest version (${REMOTE_VERSION})."
        fi
        return 0
    fi

    if [ "$local_version" != "$REMOTE_VERSION" ] && [ "${JSON}" -eq 0 ]; then
        info "Updating from ${local_version} → ${REMOTE_VERSION}"
    fi

    FORCE_REINSTALL=1
    perform_self_install_v2
}

# =============================================================================
# self_uninstall_v2() - Remove ${APP_NAME} from the system
# =============================================================================
#
# GENERAL PURPOSE:
# Removes the installed ${APP_NAME} binary (global or user) and cleans up the PATH
# entry added by the installer in shell config files.
#
# Respects --force, --quiet, and --json.
# Works for both root and user installations.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# Confirmation now uses prompt_yes_no() as SINGLE SOURCE OF TRUTH.
# Designed to be robust and reversible where possible.
#
# Last aligned: 20 April 2026
# =============================================================================

self_uninstall_v2() {
    if [ "${JSON}" -eq 0 ]; then
        info "Starting self-uninstall of ${APP_NAME}..."
    fi

    local bin_path=""
    local removed=0

    # Determine which installation to remove
    if [ "$(id -u)" -eq 0 ] || [ "${FORCE_GLOBAL:-0}" -eq 1 ]; then
        # Global (root) uninstall
        if [ -f "${GLOBAL_BIN}/${APP_NAME}" ]; then
            bin_path="${GLOBAL_BIN}/${APP_NAME}"
        fi
    else
        # User uninstall - prefer local, fallback to global if present
        if [ -f "${USER_BIN}/${APP_NAME}" ]; then
            bin_path="${USER_BIN}/${APP_NAME}"
        elif [ -f "${GLOBAL_BIN}/${APP_NAME}" ]; then
            bin_path="${GLOBAL_BIN}/${APP_NAME}"
            if [ "${JSON}" -eq 0 ]; then
                warn "Global installation found. Removing it (you may need sudo next time)."
            fi
        fi
    fi

    if [ -z "$bin_path" ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json "success" "message" "${APP_NAME} is not installed. Nothing to uninstall."
        else
            if [ "${FORCE_REINSTALL:-0}" -eq 1 ] || [ "${FORCE_USER:-0}" -eq 1 ] || [ "${FORCE_GLOBAL:-0}" -eq 1 ]; then
                warn "${APP_NAME} is not installed. Nothing to uninstall."
            else
                warn "${APP_NAME} is not installed."
            fi
        fi
        return 0
    fi

    # Confirm before removal (unless --force or non-interactive)
    # Uses prompt_yes_no() as SINGLE SOURCE OF TRUTH
    if [ "${FORCE_REINSTALL:-0}" -eq 0 ]; then
        if prompt_yes_no "This will remove: ${bin_path}"; then
            :  # user confirmed yes → continue
        else
            if [ "${JSON}" -eq 1 ]; then
                output_json "success" "message" "Uninstall cancelled by user."
            else
                msg "Uninstall cancelled by user."
            fi
            return 0 
        fi
    fi

    # Remove the binary
    if rm -f "$bin_path" 2>/dev/null; then
        removed=1
    else
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Failed to remove ${bin_path} (permission denied?)" "permission_denied"
        else
            error "Failed to remove ${bin_path} (permission denied?)"
        fi
        return 1
    fi

    # Optional: clean up PATH entry in shell configs (user only)
    if [ "$(id -u)" -ne 0 ] && [ "$removed" -eq 1 ]; then
        local cleaned=0
        for config in "${HOME}/.bashrc" "${HOME}/.zshrc" "${HOME}/.config/fish/config.fish"; do
            if [ -f "$config" ]; then
                if sed -i.bak '/# Added by .* installer/d' "$config" 2>/dev/null && \
                sed -i.bak '/\.local\/bin:.*PATH/d' "$config" 2>/dev/null; then
                    cleaned=1
                fi
                rm -f "${config}.bak" 2>/dev/null || true
            fi
        done
        if [ "$cleaned" -eq 1 ] && [ "${JSON}" -eq 0 ]; then
            msg "→ Cleaned ${APP_NAME} PATH entries from shell config files"
            msg "→ You may want to restart your terminal"
        fi
    fi

    if [ "${JSON}" -eq 1 ]; then
        output_json "success" "message" "${APP_NAME} has been uninstalled."
    else
        success "${APP_NAME} has been uninstalled."
    fi
    return 0
}

# =============================================================================
# in_path() - Check if a directory is in $PATH
# =============================================================================
#
# GENERAL PURPOSE:
# Returns 0 if the given directory (default: INSTALL_DIR) is already in $PATH.
# POSIX-compatible using case statement (works in sh/dash/bash/zsh).
#
# !!! DO NOT MODIFY OR SIMPLIFY !!!
# Designed to be reusable in other projects.
# =============================================================================

in_path() {
    case ":${PATH}:" in
        *:"${1:-$USER_BIN}":*) return 0 ;;
        *) return 1 ;;
    esac
}

# =============================================================================
# add_to_shell_path() - Multi-shell PATH support (bash + zsh + fish)
# =============================================================================
#
# GENERAL PURPOSE:
# Adds ~/.local/bin to the user's shell configuration for bash, zsh, and fish.
# Works even if the user is currently using a different shell.
#
# !!! DO NOT MODIFY OR SIMPLIFY !!!
# Designed to be reusable in other projects.
# =============================================================================

add_to_shell_path() {
    local added=0
    local shell_config="N/A"

    # Bash
    local bashrc="${HOME}/.bashrc"
    if [ -f "$bashrc" ]; then
        if [ "$shell_config" = "N/A" ]; then
            shell_config="${bashrc}"
        else
            shell_config="${shell_config} ${bashrc}"
        fi
        if ! grep -qF 'export PATH="$HOME/.local/bin:$PATH"' "$bashrc" 2>/dev/null; then
            printf "\n# Added by %s installer (%s)\n" "$APP_NAME" "$VERSION" >> "$bashrc"
            printf 'export PATH="$HOME/.local/bin:$PATH"\n' >> "$bashrc"
            added=1
            if [ "${JSON}" -eq 0 ]; then
                msg "→ Added ~/.local/bin to PATH for bash"
            fi
        fi
    fi

    # Zsh
    local zshrc="${HOME}/.zshrc"
    if [ -f "$zshrc" ]; then
        if [ "$shell_config" = "N/A" ]; then
            shell_config="${zshrc}"
        else
            shell_config="${shell_config} ${zshrc}"
        fi
        if ! grep -qF 'export PATH="$HOME/.local/bin:$PATH"' "$zshrc" 2>/dev/null; then
            printf "\n# Added by %s installer (%s)\n" "$APP_NAME" "$VERSION" >> "$zshrc"
            printf 'export PATH="$HOME/.local/bin:$PATH"\n' >> "$zshrc"
            added=1
            if [ "${JSON}" -eq 0 ]; then
                msg "→ Added ~/.local/bin to PATH for zsh"
            fi
        fi
    fi

    # Fish
    local fish_config="${HOME}/.config/fish/config.fish"
    if [ -d "${HOME}/.config/fish" ] || mkdir -p "${HOME}/.config/fish" 2>/dev/null; then
        if [ "$shell_config" = "N/A" ]; then
            shell_config="${fish_config}"
        else
            shell_config="${shell_config} ${fish_config}"
        fi
        if [ -f "$fish_config" ] && grep -qF 'set -gx PATH $HOME/.local/bin $PATH' "$fish_config" 2>/dev/null; then
            : # already present
        else
            printf "\n# Added by %s installer (%s)\n" "$APP_NAME" "$VERSION" >> "$fish_config"
            printf 'set -gx PATH $HOME/.local/bin $PATH\n' >> "$fish_config"
            added=1
            if [ "${JSON}" -eq 0 ]; then
                msg "→ Added ~/.local/bin to PATH for fish shell"
            fi
        fi
    fi

    if [ "$added" -eq 1 ] && [ "${JSON}" -eq 0 ]; then
        msg "→ Restart your terminal or run: source ${shell_config}"
    fi
}

# =============================================================================
# SELF-INSTALL LOGIC - UPDATED TO v2 (April 2026)
# =============================================================================
#
# CRITICAL DEFENSIVE FUNCTION - DO NOT SIMPLIFY, REMOVE, OR REFACTOR
#
# New in v2 (perform_self_install_v2):
#   1. If environment variable CHECKSUM=<sha256> is set (e.g. exported by user or CI),
#      the script will:
#        • Download the script from ${SCRIPT_URL}
#        • Verify the downloaded content against the provided CHECKSUM using sha256sum
#        • Only proceed with installation if the checksum matches exactly
#        • This allows users/CI to pin a known-good version and protect against
#          MITM, compromised GitHub raw, or network tampering.
#
#   2. If CHECKSUM is NOT set (normal interactive/one-liner usage):
#        • First attempt: curl ${SCRIPT_URL} (the script itself)
#        • Second attempt: also fetch ${SCRIPT_URL}.sha256 (if HTTP 200)
#        • If the .sha256 file exists and is valid, verify the downloaded script
#          with "sha256sum -c"
#        • If verification fails → die with clear error (incorrect checksum)
#        • If no .sha256 file or verification skipped → proceed (backward compatible)
#
# Why this v2 protection is needed (Defensive Reasoning):
#   • The classic `curl | sh` pattern is convenient but inherently risky.
#   • GitHub raw content can be tampered with via account compromise, supply-chain attack,
#     or transient network interception.
#   • Providing both an explicit CHECKSUM env var and automatic .sha256 lookup
#     significantly reduces the attack surface for one-command installs.
#   • Maintains full backward compatibility for users who do not provide CHECKSUM.
#   • Aligns with CIAO-Lite "Caution" and "Over-protect" principles.
#   • Prevents silent installation of malicious code — fail loudly on checksum mismatch.
#
# Updated from previous version:
#   • Old: perform_self_install() performed blind download + move.
#   • New: perform_self_install_v2() adds layered checksum verification while keeping
#     the rest of the installation logic (temp file, permissions, PATH handling) identical.
#   • The function name was deliberately changed to perform_self_install_v2 to clearly
#     signal the security upgrade. Old name is preserved in comments for reference.
#   • All other self-update / self-uninstall logic continues to call the v2 version.
#
# !!! THIS IS THE SINGLE SOURCE OF TRUTH FOR SELF-INSTALLATION !!!
# !!! DO NOT RENAME BACK, DO NOT MERGE WITH OTHER FUNCTIONS !!!
# !!! ALWAYS CALL perform_self_install_v2() FOR NEW INSTALLS !!!
# Shebang remains #!/bin/sh - defensive and portable.
# Repeated safe defaults and heavy comments are intentional.
#
# Aligned with https://github.com/Wilgat/ciao
# Last aligned: 20 April 2026
# =============================================================================

perform_self_install_v2() {
    : "${GLOBAL_BIN:=/usr/local/bin}"
    : "${USER_BIN:=${HOME}/.local/bin}"
    : "${INSTALL_PATH:=${GLOBAL_BIN}/${APP_NAME}}"

    if [ "$(id -u)" -eq 0 ]; then
        IS_ROOT=1
        INSTALL_PATH="${GLOBAL_BIN}/${APP_NAME}"
    else
        IS_ROOT=0
        INSTALL_PATH="${USER_BIN}/${APP_NAME}"
    fi

    if [ -z "$REMOTE_VERSION" ]; then
        REMOTE_VERSION=${VERSION}
    fi

    if [ "${JSON}" -eq 0 ]; then
        info "Starting installation of ${APP_NAME} ${REMOTE_VERSION}..."
    fi

    if is_installed && [ "${FORCE_REINSTALL}" -eq 0 ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json "success" "message" "${APP_NAME} is already installed."
        else
            success "${APP_NAME} is already installed. Use --force to override."
        fi
        return 0
    fi

    # Create correct target directory (root vs user)
    if [ "$IS_ROOT" -eq 1 ]; then
        if ! mkdir -p "${GLOBAL_BIN}" 2>/dev/null; then
            if [ "${JSON}" -eq 1 ]; then
                output_json_error "Failed to create ${GLOBAL_BIN}" "io_error"
            else
                error "Failed to create ${GLOBAL_BIN}"
            fi
            return 1
        fi
    else
        if ! mkdir -p "${USER_BIN}" 2>/dev/null; then
            if [ "${JSON}" -eq 1 ]; then
                output_json_error "Failed to create ${USER_BIN}" "io_error"
            else
                error "Failed to create ${USER_BIN}"
            fi
            return 1
        fi
    fi

    local tmp_file
    tmp_file=$(mktemp -t "${APP_NAME}.XXXXXX") || {
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Failed to create temporary file" "io_error"
        else
            error "Failed to create temporary file"
        fi
        return 1
    }

    if [ "${JSON}" -eq 0 ]; then
        info "Downloading ${APP_NAME} from GitHub..."
    fi

    # =============================================================================
    # CHECKSUM VERIFICATION LAYER (v2 security upgrade)
    # =============================================================================
    local downloaded_checksum_ok=0

    if [ -n "${CHECKSUM:-}" ]; then
        # Explicit CHECKSUM provided by user/CI → strict verification
        if [ "${JSON}" -eq 0 ]; then
            info "Verifying download against provided CHECKSUM..."
        fi

        if command -v curl >/dev/null 2>&1; then
            curl -fsSL "${SCRIPT_URL}" -o "${tmp_file}" || {
                rm -f "${tmp_file}"
                if [ "${JSON}" -eq 1 ]; then
                    output_json_error "Download failed (curl)" "network_error"
                else
                    error "Download failed (curl)"
                fi
                return 1
            }
        elif command -v wget >/dev/null 2>&1; then
            wget -qO "${tmp_file}" "${SCRIPT_URL}" || {
                rm -f "${tmp_file}"
                if [ "${JSON}" -eq 1 ]; then
                    output_json_error "Download failed (wget)" "network_error"
                else
                    error "Download failed (wget)"
                fi
                return 1
            }
        else
            rm -f "${tmp_file}"
            if [ "${JSON}" -eq 1 ]; then
                output_json_error "Neither curl nor wget found" "missing_dependency"
            else
                error "Neither curl nor wget found"
            fi
            return 1
        fi

        # Verify provided CHECKSUM
        if printf '%s  %s\n' "${CHECKSUM}" "${tmp_file}" | sha256sum -c - >/dev/null 2>&1; then
            downloaded_checksum_ok=1
            if [ "${JSON}" -eq 0 ]; then
                success "Checksum verification passed (user-provided CHECKSUM)."
            fi
        else
            rm -f "${tmp_file}"
            if [ "${JSON}" -eq 1 ]; then
                output_json_error "Checksum verification failed (provided CHECKSUM does not match)" "checksum_mismatch"
            else
                die "Checksum verification failed. The downloaded file does not match the provided CHECKSUM. Installation aborted for security."
            fi
            return 1
        fi

    else
        # No explicit CHECKSUM → try automatic .sha256 file (best-effort)
        if [ "${JSON}" -eq 0 ]; then
            info "No CHECKSUM provided → attempting automatic verification via ${SCRIPT_URL}.sha256"
        fi

        if command -v curl >/dev/null 2>&1; then
            # Primary download
            curl -fsSL "${SCRIPT_URL}" -o "${tmp_file}" || {
                rm -f "${tmp_file}"
                if [ "${JSON}" -eq 1 ]; then
                    output_json_error "Download failed (curl)" "network_error"
                else
                    error "Download failed (curl)"
                fi
                return 1
            }

            # Try to fetch .sha256 sidecar
            local sha_file
            sha_file=$(mktemp -t "${APP_NAME}.sha256.XXXXXX") || {
                rm -f "${tmp_file}"
                return 1
            }

            if curl -fsSL -w "%{http_code}" "${SCRIPT_URL}.sha256" -o "${sha_file}" 2>/dev/null | grep -q "^200"; then
                if sha256sum -c "${sha_file}" --status 2>/dev/null < "${tmp_file}"; then
                    downloaded_checksum_ok=1
                    if [ "${JSON}" -eq 0 ]; then
                        success "Automatic checksum verification passed (${SCRIPT_URL}.sha256)."
                    fi
                else
                    rm -f "${tmp_file}" "${sha_file}"
                    if [ "${JSON}" -eq 1 ]; then
                        output_json_error "Automatic checksum verification failed" "checksum_mismatch"
                    else
                        die "Checksum verification failed (mismatch with ${SCRIPT_URL}.sha256). Installation aborted for security."
                    fi
                    return 1
                fi
            else
                # No .sha256 available → proceed without verification (backward compatible)
                if [ "${JSON}" -eq 0 ]; then
                    warn "No .sha256 file found at ${SCRIPT_URL}.sha256 → continuing without automatic verification."
                fi
            fi
            rm -f "${sha_file}" 2>/dev/null || true

        elif command -v wget >/dev/null 2>&1; then
            # Similar logic for wget (kept minimal and defensive)
            wget -qO "${tmp_file}" "${SCRIPT_URL}" || {
                rm -f "${tmp_file}"
                if [ "${JSON}" -eq 1 ]; then
                    output_json_error "Download failed (wget)" "network_error"
                else
                    error "Download failed (wget)"
                fi
                return 1
            }

            local sha_file
            sha_file=$(mktemp -t "${APP_NAME}.sha256.XXXXXX") || {
                rm -f "${tmp_file}"
                return 1
            }

            if wget -q --server-response "${SCRIPT_URL}.sha256" -O "${sha_file}" 2>&1 | grep -q "HTTP/1.1 200"; then
                if sha256sum -c "${sha_file}" --status 2>/dev/null < "${tmp_file}"; then
                    downloaded_checksum_ok=1
                    if [ "${JSON}" -eq 0 ]; then
                        success "Automatic checksum verification passed."
                    fi
                else
                    rm -f "${tmp_file}" "${sha_file}"
                    if [ "${JSON}" -eq 1 ]; then
                        output_json_error "Automatic checksum verification failed" "checksum_mismatch"
                    else
                        die "Checksum verification failed. Installation aborted for security."
                    fi
                    return 1
                fi
            else
                if [ "${JSON}" -eq 0 ]; then
                    warn "No .sha256 file found → continuing without automatic verification."
                fi
            fi
            rm -f "${sha_file}" 2>/dev/null || true
        else
            rm -f "${tmp_file}"
            if [ "${JSON}" -eq 1 ]; then
                output_json_error "Neither curl nor wget found" "missing_dependency"
            else
                error "Neither curl nor wget found"
            fi
            return 1
        fi
    fi

    # Final safety: if we reached here without explicit failure, file is in tmp_file
    chmod +x "${tmp_file}" 2>/dev/null || true

    rm -f "${INSTALL_PATH}" 2>/dev/null
    if ! mv "${tmp_file}" "${INSTALL_PATH}" 2>/dev/null; then
        rm -f "${tmp_file}"
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Failed to move to ${INSTALL_PATH}" "io_error"
        else
            error "Failed to move to ${INSTALL_PATH}"
        fi
        return 1
    fi

    # Add ~/.local/bin to PATH for normal user installs
    if [ "$IS_ROOT" -eq 0 ]; then
        add_to_shell_path
    fi
    
    if [ "${JSON}" -eq 1 ]; then
        output_json "success" "message" "${APP_NAME} ${REMOTE_VERSION} successfully installed to ${INSTALL_PATH}"
    else
        success "${APP_NAME} ${REMOTE_VERSION} successfully installed to ${INSTALL_PATH}"
        if [ "${downloaded_checksum_ok}" -eq 1 ]; then
            success "✓ Download was cryptographically verified."
        fi
    fi
    return 0
}

# =============================================================================
# prompt_yes_no() - Defensive interactive yes/no confirmation prompt
# =============================================================================
#
# GENERAL PURPOSE:
# Displays a message and waits for (y/N) confirmation.
# Returns 0 if user says yes, returns 1 (non-zero) if user says no or cancels.
#
# CRITICAL DEFENSIVE RULES (DO NOT VIOLATE):
# 1. Must ALWAYS go through single source of truth (msg_n + output_text)
# 2. Must respect --quiet and --json (never show prompt in those modes)
# 3. Must NEVER use raw printf/echo for user-visible text
# 4. Must work correctly in non-interactive / curl | sh environments
# 5. Must preserve TTY detection and color handling via output_text
# 6. This is the SINGLE SOURCE OF TRUTH for all yes/no confirmations in the project.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# Past AI assistants have repeatedly replaced this kind of prompt with
# raw printf + read, breaking consistency with output_text(), --quiet,
# --json, TTY detection, and the overall defensive design.
#
# This helper exists specifically to prevent that regression and to enforce
# CIAO-Lite principles of Caution, Intentionality, and Over-protect.
#
# Last reviewed & aligned: 22 April 2026
# =============================================================================

prompt_yes_no() {
    # --- Safe Variable Defaults ----
    # Defensive defaults - never assume globals are set
    : "${JSON:=0}"
    : "${QUIET:=0}"

    local message="$1"

    # Never show prompt in quiet or json mode
    if [ "${JSON}" -eq 1 ] || [ "${QUIET}" -eq 1 ]; then
        return 1   # treat as "no" in non-interactive modes
    fi

    # Must be interactive TTY
    if ! [ -t 0 ] || ! [ -t 1 ]; then
        return 1
    fi

    msg_n "${message} (y/N)? "

    local answer=""
    read -r answer || true

    case "$answer" in
        [Yy]*|[Yy][Ee][Ss]*)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

# =============================================================================
# maybe_install_v4() - Friendly installation prompt
# =============================================================================
#
# Respects both --quiet and --json modes.
# In JSON mode we skip the interactive prompt entirely.
# Now uses prompt_yes_no() as single source of truth for confirmation.
#
# !!! DO NOT MODIFY OR SIMPLIFY !!!
# Designed to be reusable in other projects.
#
# Last aligned: 20 April 2026
# =============================================================================

maybe_install_v4() {
    if is_installed && [ "${FORCE_REINSTALL}" -eq 0 ]; then
        return 0
    fi

    # In JSON mode or quiet mode we do not show interactive prompts
    if [ "${JSON}" -eq 1 ] || [ "${QUIET}" -eq 1 ]; then
        return 0
    fi

    empty_line
    msg "Note: '${APP_NAME}' is not installed yet."
    msg "     Version: ${VERSION}"
    empty_line
    msg "Recommended installation command:"
    empty_line

    if [ "$IS_ROOT" -eq 1 ]; then
        msg "     sudo curl -fsSL ${SCRIPT_URL} | sudo ${SH}"
    else
        msg "     curl -fsSL ${SCRIPT_URL} | ${SH}"
    fi
    empty_line

    local should_install=false

    if [ -t 0 ] && [ -t 1 ]; then
        # Use single source of truth for the yes/no prompt
        if prompt_yes_no "Install ${APP_NAME} ${VERSION} now?"; then
            should_install=true
        else
            should_install=false
            msg "Installation skipped by user."
            return 0 
        fi
    else
        msg "Non-interactive mode detected → installing automatically..."
        should_install=true
    fi

    if [ "$should_install" = "true" ]; then
        perform_self_install_v2
        exit 0
    fi
}


# =============================================================================
# show_about_git_sync() - Display diagnostic information about the current environment
# =============================================================================
#
# GENERAL PURPOSE:
# Shows detailed diagnostic information: version, installation status (global + local),
# current shell, TTY/interactive status, user, and helpful next steps.
#
# Fully respects --quiet and --json modes.
# In JSON mode: outputs exactly ONE clean, machine-readable JSON object.
# In quiet mode: prints nothing.
#
# This function provides real value to users (unlike the previous overly simple version)
# and should be kept in sync with the overall CIAO design and README.md.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# Designed to be reusable in other CIAO projects.
# Last reviewed: April 2026
# =============================================================================
show_about_git_sync() {
    if [ "${JSON}" -eq 1 ]; then
        # === JSON MODE - Clean, machine-friendly output ===
        local installed="false"
        is_installed && installed="true"

        local global_ver="not found"
        if [ -x "${GLOBAL_BIN}/${APP_NAME}" ]; then
            global_ver=$(grep '^VERSION="' "${GLOBAL_BIN}/${APP_NAME}" 2>/dev/null | cut -d'"' -f2 || echo "unknown")
        fi

        local local_ver="not found"
        if [ -x "${USER_BIN}/${APP_NAME}" ]; then
            local_ver=$(grep '^VERSION="' "${USER_BIN}/${APP_NAME}" 2>/dev/null | cut -d'"' -f2 || echo "unknown")
        fi

        # Improved shell detection to avoid showing the script name itself
        local current_shell="unknown"
        current_shell=$(ps -p $$ -o comm= 2>/dev/null | tr -d '()' || echo "unknown")
        
        if [ "$current_shell" = "${APP_NAME}" ] || [ "$current_shell" = "sh" ] || \
           [ "$current_shell" = "dash" ] || [ "$current_shell" = "ash" ]; then
            local parent_pid
            parent_pid=$(ps -p $$ -o ppid= 2>/dev/null | tr -d ' ')
            if [ -n "$parent_pid" ]; then
                current_shell=$(ps -p "$parent_pid" -o comm= 2>/dev/null | tr -d '()' || echo "$current_shell")
            fi
        fi

        local interactive="false"
        [ -t 1 ] && interactive="true"

        output_json "about" "" \
            "app" "${APP_NAME}" \
            "version" "${VERSION}" \
            "installed" "${installed}" \
            "global_version" "${global_ver}" \
            "local_version" "${local_ver}" \
            "shell" "${current_shell}" \
            "interactive" "${interactive}" \
            "user" "${USERNAME}" 

        return 0
    fi

    # === Normal Human-readable Mode ===
    [ "${QUIET}" -eq 1 ] && return 0

    msg "=== ${APP_NAME} ${VERSION} - About / Diagnostics ==="
    empty_line

    # Installation status
    if is_installed; then
        success "${APP_NAME} is properly installed."
    else
        warn "${APP_NAME} is NOT installed in your PATH."
        if [ -t 1 ]; then
            msg "   Recommended one-liner:"
            msg "     curl -fsSL ${SCRIPT_URL} | sh"
        else
            msg "   Recommended: curl -fsSL ${SCRIPT_URL} | sh"
        fi
    fi

    empty_line

    # Global vs Local installation details
    if [ -x "${GLOBAL_BIN}/${APP_NAME}" ]; then
        global_ver=$(grep '^VERSION="' "${GLOBAL_BIN}/${APP_NAME}" 2>/dev/null | cut -d'"' -f2 || echo "unknown")
        msg "Global install  (${GLOBAL_BIN}/${APP_NAME}):   ${global_ver}"
    else
        msg "Global install  (${GLOBAL_BIN}/${APP_NAME}):   not found"
    fi

    if [ -x "${USER_BIN}/${APP_NAME}" ]; then
        local_ver=$(grep '^VERSION="' "${USER_BIN}/${APP_NAME}" 2>/dev/null | cut -d'"' -f2 || echo "unknown")
        msg "Local install   (${USER_BIN}/${APP_NAME}):    ${local_ver}"
    else
        msg "Local install   (${USER_BIN}/${APP_NAME}):    not found"
    fi

    empty_line

    # Shell & Environment
    local current_shell="unknown"
    current_shell=$(ps -p $$ -o comm= 2>/dev/null | tr -d '()' || echo "unknown")
    
    if [ "$current_shell" = "${APP_NAME}" ] || [ "$current_shell" = "sh" ] || \
       [ "$current_shell" = "dash" ] || [ "$current_shell" = "ash" ]; then
        local parent_pid
        parent_pid=$(ps -p $$ -o ppid= 2>/dev/null | tr -d ' ')
        if [ -n "$parent_pid" ]; then
            current_shell=$(ps -p "$parent_pid" -o comm= 2>/dev/null | tr -d '()' || echo "$current_shell")
        fi
    fi

    msg "Current shell:     ${current_shell}"
    msg "User:              ${USERNAME}"

    if [ -t 1 ]; then
        msg "TTY / Interactive: yes"
    else
        msg "TTY / Interactive: no (non-interactive / scripted mode)"
    fi

    empty_line
    msg "Useful commands:"
    msg "   ${APP_NAME} help          → Full usage and examples"
    msg "   ${APP_NAME} self-update   → Update to latest version"
    msg "   ${APP_NAME} self-uninstall → Clean removal from system"
    msg "   ${APP_NAME} --json        → Machine-readable output"

    empty_line
    msg "Run '${APP_NAME} help' for complete usage information."
}

