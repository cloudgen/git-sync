# =============================================================================
# output_text() - SINGLE SOURCE OF TRUTH FOR ALL OUTPUT
# =============================================================================
#
# GENERAL PURPOSE:
# Centralized output handler for all human-readable messages.
# Respects --quiet, --json, and TTY detection for colors.
# All user-facing text (info, success, warn, error, etc.) MUST go through this
# function to maintain consistency and JSON-mode compatibility.
#
# INTENTIONAL DESIGN:
# This is the single source of truth for all terminal output in the project.
# Never use raw echo/printf for user messages elsewhere.
#
# Last reviewed: 28 April 2026
# =============================================================================
output_text() {
    local level="$1" msg="$2"
    : "${JSON:=0}" : "${QUIET:=0}"
    [ "${JSON}" -eq 1 ] && return 0
    [ "${QUIET}" -eq 1 ] && [ "${level}" != "error" ] && return 0

    local RED='' GREEN='' YELLOW='' BLUE='' NC=''
    [ "${TTY:-0}" -eq 1 ] && [ "${QUIET}" -eq 0 ] && [ "${JSON}" -eq 0 ] && {
        RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; NC='\033[0m'
    }

    case "${level}" in
        error) printf >&2 "${RED}[ERROR]${NC} %s\n" "${msg}" ;; warn) printf >&2 "${YELLOW}[WARN]${NC} %s\n" "${msg}" ;;
        info) printf "${GREEN}[INFO]${NC} %s\n" "${msg}" ;; success) printf "${GREEN}[OK]${NC} %s\n" "${msg}" ;;
        plain) printf "%s\n" "${msg}" ;; plain_n) printf "%s" "${msg}" ;;
        *) printf "%s\n" "${msg}" ;;
    esac
}

# =============================================================================
# output_json() - JSON output helper
# =============================================================================
#
# GENERAL PURPOSE:
# Emits clean, machine-readable JSON when --json flag is used.
# Used by all command modes that support structured output.
#
# INTENTIONAL DESIGN:
# Keeps JSON output minimal, consistent, and escaped safely.
# Must be used together with output_json_error() for errors.
#
# Last reviewed: 28 April 2026
# =============================================================================

output_json() {
    [ "${JSON}" -eq 0 ] && return 0
    local type="$1" message="$2"; shift 2
    printf '{'
    printf '"type":"%s"' "$type"
    [ -n "$message" ] && printf ',"message":"%s"' "$(printf '%s' "$message" | sed 's/"/\\"/g')"
    while [ $# -ge 2 ]; do printf ',"%s":"%s"' "$1" "$2"; shift 2; done
    printf '}\n'

}

