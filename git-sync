# =============================================================================
# git_sync_main_loop() - Main synchronization loop for Git repositories
# =============================================================================
#
# GENERAL PURPOSE:
# Scans the given START_DIR (default: current directory) for direct
# subfolders containing a .git directory, then calls git_sync_per_repo()
# on each one.
#
# Includes defensive directory existence check and clear progress output.
#
# DESIGN INTENT:
# Keeps the core Git logic simple, readable, and tolerant (continues on
# individual repo failures). This is the main business logic of git-sync.
#
# CRITICAL:
# Do NOT add recursive scanning or complex filters unless explicitly
# requested by the user — this function is intentionally limited to
# direct subfolders per the original project specification.
#
# Last reviewed: 28 April 2026
# =============================================================================

git_sync_main_loop() {
    local START_DIR="${1:-.}"
    if [ ! -d "$START_DIR" ]; then
        die "Start directory does not exist: $START_DIR"
    fi
    output_text plain "🔍 Checking subfolders under: $START_DIR"
    double_line
    local found=0
    for dir in "$START_DIR"/*/; do
        [ -d "$dir" ] || continue
        repo_dir="${dir%/}"
        [ -d "$repo_dir/.git" ] || continue
        git_sync_per_repo "$repo_dir"
        found=1
    done
    [ "$found" -eq 0 ] && warn "No Git repos (.git) found in $START_DIR"
    success "🎉 Finished all repos!"
}
# =============================================================================
# git_sync_per_repo() - Process a single Git repository
# =============================================================================
#
# GENERAL PURPOSE:
# Performs reset --hard + pull origin main on a single repository.
# Runs inside a subshell to isolate directory changes and failures.
#
# SAFETY:
# Failures in reset are fatal for that repo; pull failures are warnings
# (common when already up-to-date).
#
# Last reviewed: 28 April 2026
# =============================================================================

git_sync_per_repo() {
    local repo_dir="$1"
    output_text plain "📂 Processing Git repo: $repo_dir"
    (
        cd "$repo_dir" || { output_text error "cd $repo_dir failed"; exit 1; }
        output_text plain "   🔄 Resetting --hard..."
        git reset --hard HEAD || { output_text error "git reset failed"; exit 1; }
        output_text plain "   ⬇️  Pulling from origin main..."
        if ! git pull origin main; then
            output_text warn "git pull failed (already up-to-date or error?)"
        fi
    ) || {
        output_text error "Failed to process repo: $repo_dir"
        return 1
    }
    output_text plain "--------------------------------------------------"
}

# =============================================================================
# main_git_sync() - Main dispatcher for the git-sync tool
# =============================================================================
#
# Handles argument parsing and routes to the correct git-sync functions.
# Supports the desired syntax:
#   countdown sync 
#
# IMPORTANT DESIGN DECISION:
#   The auto-install logic (`maybe_install` / `perform_self_install`) is triggered
#   when the script is run with ZERO arguments via `curl | sh`.
#
#   This is INTENTIONAL and CRITICAL for the one-liner installer to work.
#   Without it, `curl -fsSL ... | sh` would only print help and exit, leaving
#   the user with "command not found" — exactly the problem we are solving.
#
#   Even though subcommands like "help", "version", or "about" exist,
#   we still want to check/install first in the curl | sh context because
#   the primary use-case of piping the raw script is installation.
#
#   This pattern is common in robust single-file CLI tools and must be preserved.
#
# !!! DO NOT REMOVE OR SIMPLIFY THE AUTO-INSTALL BLOCK !!!
#   Many AI assistants will try to "clean it up", move it after parsing,
#   or tie it only to specific subcommands.
#   Doing so would break the one-liner installation experience (`curl | sh`),
#   which is one of the core promises of this project.
#
#   Previous Grok versions already attempted to remove or relocate this logic.
#   Respect this decision and keep the auto-install check at the top, before
#   any argument parsing.
# =============================================================================
main_git_sync() {
    # === AUTO-INSTALL FOR ONE-LINER (curl | sh) ===
    # This block MUST stay at the very top, before any argument parsing.
    # It ensures that `curl ... | sh` actually installs the tool instead of
    # just showing help and exiting with "command not found".
    #
    # perform_self_install / maybe_install is important here EVEN THOUGH
    # a subcommand may be present later, because the main real-world usage
    # of this script is the one-liner installer. Installing first is the
    # expected behavior in that context.

    if ! is_installed && [ $# -eq 0 ]; then
        if [ "${JSON}" -eq 1 ] || [ "${QUIET}" -eq 1 ]; then
            # Non-interactive / JSON mode → install silently
            perform_self_install
        else
            maybe_install
        fi
    fi

    # === Phase 1: Parse all arguments (fixed start command) ===
    local cmd="$1";
    while [ $# -gt 0 ]; do
        case "$1" in
            --quiet|-q)
                QUIET=1
                ;;
            --json)
                JSON=1
                QUIET=1
                ;;
            sync|help|version|about|version-check|self-update|self-uninstall)
                cmd="${1#--}"
                ;;
        esac
        shift
    done

    case "$cmd" in
        ""|sync) git_sync_main_loop "$1" ;;
        help) show_about_git_help ;;
        version) 
            if [ "${JSON}" -eq 1 ]; then
                output_json "version" "" \
                    "app" "${APP_NAME}" \
                    "version" "${VERSION}"
            else
                msg "${APP_NAME} version ${VERSION}"
            fi
            ;;
        version-check) version_check ;;
        self-update) self_update ;;
        self-uninstall) self_uninstall ;;
        about) show_about_git_sync ;;
        --quiet|--json) QUIET=1; [ "$1" = "--json" ] && JSON=1; main_git_sync "$@" ;;
        *) die "Unknown: $cmd. Run ${APP_NAME} help" ;;
    esac
}

main_git_sync "$@"
