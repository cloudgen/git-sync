#!/bin/sh
# =============================================================================
# git-sync – version 1.0.7
# =============================================================================
#
# Scans direct subfolders for Git repos (.git), resets --hard HEAD, pulls origin main.
# Portable, self-installing — works via curl | sh.
#
# One-liner: curl -fsSL https://raw.githubusercontent.com/cloudgen/git-sync/main/git-sync | sh
#
# Now structured for easier maintenance with ShellParser[](https://github.com/cloudgen/ShellParser)
# Core remains single-file for curl | sh compatibility.
#
# See [CIAO](https://github.com/cloudgen/ciao)
# =============================================================================

# ----------------------------- Project Constants -----------------------------
APP_NAME="git-sync"            # HARDCODED for curl | sh
VERSION="1.0.7"
DESCRIPTION="Git reset+pull for subfolder repos"
REPO_USER="cloudgen"               
REPO_NAME="git-sync"
SCRIPT_URL="https://raw.githubusercontent.com/${REPO_USER}/${REPO_NAME}/main/${APP_NAME}"

# Force/Mode Flags (defaults)
: "${FORCE_USER:=0}"
: "${FORCE_GLOBAL:=0}"
: "${FORCE_REINSTALL:=0}"
: "${QUIET:=0}"
: "${JSON:=0}"

# Paths (defensive defaults)
: "${GLOBAL_BIN:=/usr/local/bin}"
: "${USER_BIN:=${HOME}/.local/bin}"
: "${INSTALL_PATH:=${GLOBAL_BIN}/${APP_NAME}}"

# =============================================================================
# Root Detection (Single Source of Truth)
# =============================================================================
if [ -z "${IS_ROOT:-}" ]; then
    if [ "$(id -u)" -eq 0 ]; then
        IS_ROOT=1
        INSTALL_PATH="${GLOBAL_BIN}/${APP_NAME}"
    else
        IS_ROOT=0
        INSTALL_PATH="${USER_BIN}/${APP_NAME}"
    fi
fi

[ -t 0 ] && [ -t 1 ] && TTY=1
USERNAME="$(id -un 2>/dev/null || echo unknown)"

